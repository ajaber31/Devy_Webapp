# ─────────────────────────────────────────────────────────────────────────────
# Devy — environment variable template
#
# SETUP
#   cp .env.example .env.local
#   Fill in the values below, then restart the dev server.
#
# SECURITY RULES
#   • NEVER commit .env.local or any file containing real secrets to git.
#   • Only prefix values with NEXT_PUBLIC_ when they are intentionally safe to
#     expose in the browser (e.g. Supabase project URL and anon key).
#   • The service_role key MUST NOT have a NEXT_PUBLIC_ prefix and must never
#     appear in client-side code or browser bundles.
#   • Rotate all keys immediately if you suspect they have been exposed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (safe to expose — anon key is subject to RLS) ───────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase service-role key (SERVER ONLY — never expose to browser) ────────
# Used only in admin server actions and the document processing pipeline.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── OpenAI (SERVER ONLY) ──────────────────────────────────────────────────────
# Used for chat completions (gpt-4o) and embeddings (text-embedding-3-small).
OPENAI_API_KEY=sk-proj-...

# ── App URL ───────────────────────────────────────────────────────────────────
# Used as the base for Supabase auth redirects (password reset, email confirm)
# and Stripe success/cancel redirect URLs.
# In production, set this to your real domain (e.g. https://app.devy.ca).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Stripe (SERVER ONLY — never expose secret key or webhook secret to browser) ──
# Get these from https://dashboard.stripe.com/developers
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Create two recurring CAD products in Stripe Dashboard, then paste their price IDs here.
# Product "Devy Standard"  → $15.00 CAD/month recurring
# Product "Devy Professional" → $50.00 CAD/month recurring
STRIPE_PRICE_ID_STANDARD=price_...
STRIPE_PRICE_ID_PROFESSIONAL=price_...

# ── Resend (SERVER ONLY — transactional email, optional) ──────────────────────
# Leave blank to disable email notifications entirely.
RESEND_API_KEY=re_...
